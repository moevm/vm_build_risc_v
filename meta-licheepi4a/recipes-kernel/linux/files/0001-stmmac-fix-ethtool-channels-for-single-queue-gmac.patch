From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: builder <builder@localhost>
Date: Thu, 15 May 2026 00:00:00 +0000
Subject: [PATCH] net: stmmac: fix ethtool get_channels for single-queue GMAC

On GMAC v3.x (has_gmac=1) the DMA capabilities register does not
report queue counts so dma_cap.number_rx_queues stays 0. This causes
ethtool -l to report n/a for max channels, and AF_XDP socket setup
fails because xsks_map is created with max_entries=0.

Fall back to rx/tx_queues_to_use when the hardware does not report
max queue counts.

Signed-off-by: builder <builder@localhost>
---
 drivers/net/ethernet/stmicro/stmmac/stmmac_ethtool.c | 6 ++++--
 1 file changed, 4 insertions(+), 2 deletions(-)

diff --git a/drivers/net/ethernet/stmicro/stmmac/stmmac_ethtool.c b/drivers/net/ethernet/stmicro/stmmac/stmmac_ethtool.c
--- a/drivers/net/ethernet/stmicro/stmmac/stmmac_ethtool.c
+++ b/drivers/net/ethernet/stmicro/stmmac/stmmac_ethtool.c
@@ -1173,8 +1173,10 @@ static void stmmac_get_channels(struct net_device *dev,

 	chan->rx_count = priv->plat->rx_queues_to_use;
 	chan->tx_count = priv->plat->tx_queues_to_use;
-	chan->max_rx = priv->dma_cap.number_rx_queues;
-	chan->max_tx = priv->dma_cap.number_tx_queues;
+	chan->max_rx = priv->dma_cap.number_rx_queues ?
+		priv->dma_cap.number_rx_queues : priv->plat->rx_queues_to_use;
+	chan->max_tx = priv->dma_cap.number_tx_queues ?
+		priv->dma_cap.number_tx_queues : priv->plat->tx_queues_to_use;
 }

 static int stmmac_set_channels(struct net_device *dev,
